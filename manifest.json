{
  "manifest_version": 3,
  "name": "SAP Timesheet Filler",
  "version": "1.0.0",
  "description": "Automates AGILTime timesheet entry on SAP S/4HANA Fiori",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://*.hana.ondemand.com/*", "https://*.sap.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.hana.ondemand.com/*", "https://*.sap.com/*"],
      "js": ["content/ui5-helpers.js", "content/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/page-world.js"],
      "matches": ["https://*.hana.ondemand.com/*", "https://*.sap.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
